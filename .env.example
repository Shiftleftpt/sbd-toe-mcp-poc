# Runtime normal: o bundle local já vem incluído no repositório e nos GitHub Releases.
# Não é necessário Algolia nem checkout adicional do builder semântico para usar o MCP.
DOCS_SNAPSHOT_FILE=./data/publish/algolia_docs_records.json
ENTITIES_SNAPSHOT_FILE=./data/publish/algolia_entities_records.json
INDEX_SETTINGS_FILE=./data/publish/algolia_index_settings.json
RUN_MANIFEST_FILE=./data/reports/run_manifest.json

# Os dois índices publicados pelo upstream continuam a ser a referência semântica.
SEMANTIC_BACKEND_DOCS_INDEX=SbD-ToE-ASKAI-Docs
SEMANTIC_BACKEND_ENTITIES_INDEX=SbD-ToE-ASKAI-Entities

# Prompting e links de referência.
SYSTEM_PROMPT_FILE=./prompts/sbd-toe-chat-system.md
SITE_BASE_URL=https://www.securitybydesign.dev/
MANUAL_BASE_URL=https://www.securitybydesign.dev/sbd-toe/sbd-manual/
CROSS_CHECK_BASE_URL=https://www.securitybydesign.dev/sbd-toe/cross-check-normativo/

DEFAULT_LANGUAGE=pt-PT
DEBUG_MODE=false
DOCS_HITS=8
ENTITIES_HITS=5
MAX_CONTEXT_RECORDS=8
SAMPLING_MAX_TOKENS=1200

# Configuração opcional para mantenedores que queiram atualizar o bundle embutido
# a partir de um checkout local do repositório sbd-toe-knowledge-graph.
UPSTREAM_KNOWLEDGE_GRAPH_DIR=../sbd-toe-knowledge-graph
BACKEND_CHECKOUT_FILE=./data/upstream/backend-checkout.json
